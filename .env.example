# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=smartinsights
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Backend ────────────────────────────────────────────
# Docker Compose constructs DATABASE_URL and REDIS_URL automatically.
# These values are for local development without Docker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartinsights
REDIS_URL=redis://localhost:6379/0

# ── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
